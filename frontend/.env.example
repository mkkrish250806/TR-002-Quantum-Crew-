# Frontend Environment Configuration
# Copy this file to .env.local for local development

# Backend API URL
# Default: http://127.0.0.1:8000 (local development)
# For production, replace with your backend domain
VITE_API_URL=http://127.0.0.1:8000

# Optional: Enable debug logging
VITE_DEBUG=false

# Optional: Session timeout in milliseconds (default: 30 minutes)
VITE_SESSION_TIMEOUT=1800000

# Optional: API request timeout in milliseconds (default: 15000)
VITE_API_TIMEOUT=15000

# Optional: Number of retries for failed API requests (default: 2)
VITE_API_RETRIES=2
